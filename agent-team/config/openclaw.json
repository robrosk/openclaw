{
  "auth": {
    "profiles": {
      "openai-codex:${OPERATOR_EMAIL}": {
        "provider": "openai-codex",
        "mode": "oauth",
        "email": "${OPERATOR_EMAIL}"
      }
    }
  },
  "plugins": {
    "entries": {
      "openai": {
        "enabled": true
      },
      "google": {
        "enabled": true,
        "config": {
          "webSearch": {
            "apiKey": "${GEMINI_API_KEY}"
          }
        }
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai-codex/gpt-5.4"
      },
      "models": {
        "openai-codex/gpt-5.4": {},
        "openai-codex/gpt-5.4-mini": {}
      },
      "workspace": "/home/clawadmin/.openclaw/workspace-orchestrator",
      "memorySearch": {
        "enabled": true,
        "provider": "openai"
      },
      "heartbeat": {
        "every": "1h",
        "activeHours": {
          "start": "06:00",
          "end": "18:00",
          "timezone": "America/New_York"
        },
        "target": "none",
        "lightContext": true,
        "isolatedSession": true,
        "model": "openai-codex/gpt-5.4",
        "ackMaxChars": 300,
        "suppressToolErrorWarnings": true
      }
    },
    "list": [
      {
        "id": "orchestrator",
        "default": true,
        "name": "Orchestrator - Portfolio Manager",
        "workspace": "/home/clawadmin/.openclaw/workspace-orchestrator",
        "identity": {
          "name": "Orchestrator - Portfolio Manager",
          "emoji": "⚡"
        },
        "heartbeat": {
          "every": "15m"
        }
      },
      {
        "id": "scout",
        "name": "Scout - Market Intelligence",
        "workspace": "/home/clawadmin/.openclaw/workspace-scout",
        "identity": {
          "name": "Scout - Market Intelligence"
        },
        "heartbeat": {
          "every": "45m"
        }
      },
      {
        "id": "analyst",
        "name": "Analyst - Fundamental Research",
        "workspace": "/home/clawadmin/.openclaw/workspace-analyst",
        "identity": {
          "name": "Analyst - Fundamental Research"
        },
        "heartbeat": {
          "every": "2h",
          "model": "openai-codex/gpt-5.4-mini"
        }
      },
      {
        "id": "quant",
        "name": "Quant - Technical & Quantitative",
        "workspace": "/home/clawadmin/.openclaw/workspace-quant",
        "identity": {
          "name": "Quant - Technical & Quantitative"
        },
        "heartbeat": {
          "every": "2h",
          "model": "openai-codex/gpt-5.4-mini"
        }
      },
      {
        "id": "devils-advocate",
        "name": "Devil's Advocate - Risk & Contrarian",
        "workspace": "/home/clawadmin/.openclaw/workspace-devils-advocate",
        "identity": {
          "name": "Devil's Advocate - Risk & Contrarian"
        },
        "heartbeat": {
          "every": "1h",
          "model": "openai-codex/gpt-5.4-mini"
        }
      }
    ]
  },
  "tools": {
    "profile": "full",
    "agentToAgent": {
      "enabled": true
    },
    "web": {
      "search": {
        "enabled": true,
        "provider": "gemini",
        "openaiCodex": {
          "enabled": true,
          "mode": "live"
        }
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "command-logger": {
          "enabled": true
        },
        "session-memory": {
          "enabled": true
        }
      }
    }
  },
  "channels": {
    "slack": {
      "enabled": true,
      "mode": "socket",
      "defaultAccount": "orchestrator",
      "groupPolicy": "open",
      "dangerouslyAllowNameMatching": false,
      "webhookPath": "/slack/events",
      "capabilities": {
        "interactiveReplies": true
      },
      "actions": {
        "messages": true,
        "reactions": true,
        "pins": true,
        "memberInfo": true,
        "emojiList": true
      },
      "streaming": "partial",
      "nativeStreaming": true,
      "userTokenReadOnly": true,
      "channels": {
        "${SLACK_CHANNEL_MARKET_SIGNALS}": {
          "allow": true,
          "requireMention": true,
          "allowBots": true
        },
        "${SLACK_CHANNEL_RESEARCH}": {
          "allow": true,
          "requireMention": true,
          "allowBots": true
        },
        "${SLACK_CHANNEL_QUANT_SIGNALS}": {
          "allow": true,
          "requireMention": true,
          "allowBots": true
        },
        "${SLACK_CHANNEL_CONTRARIAN}": {
          "allow": true,
          "requireMention": true,
          "allowBots": true
        },
        "${SLACK_CHANNEL_TASK_BOARD}": {
          "allow": true,
          "requireMention": true,
          "allowBots": true
        },
        "${SLACK_CHANNEL_PORTFOLIO_DAILY}": {
          "allow": true,
          "requireMention": true,
          "allowBots": false
        },
        "${SLACK_CHANNEL_PORTFOLIO_WEEKLY}": {
          "allow": true,
          "requireMention": true,
          "allowBots": false
        },
        "${SLACK_CHANNEL_THEMES}": {
          "allow": true,
          "requireMention": true,
          "allowBots": true
        },
        "${SLACK_CHANNEL_AGENTS}": {
          "allow": true,
          "requireMention": true,
          "allowBots": true
        },
        "${SLACK_CHANNEL_WATCHLIST}": {
          "allow": true,
          "requireMention": true,
          "allowBots": true
        },
        "${SLACK_CHANNEL_WEEKLY_OUTLOOK}": {
          "allow": true,
          "requireMention": true,
          "allowBots": true
        }
      },
      "accounts": {
        "orchestrator": {
          "name": "Orchestrator - Portfolio Manager",
          "botToken": "${SLACK_ORCHESTRATOR_BOT_TOKEN}",
          "appToken": "${SLACK_ORCHESTRATOR_APP_TOKEN}",
          "dmPolicy": "pairing"
        },
        "scout": {
          "name": "Scout - Market Intelligence",
          "botToken": "${SLACK_SCOUT_BOT_TOKEN}",
          "appToken": "${SLACK_SCOUT_APP_TOKEN}",
          "dmPolicy": "pairing"
        },
        "analyst": {
          "name": "Analyst - Fundamental Research",
          "botToken": "${SLACK_ANALYST_BOT_TOKEN}",
          "appToken": "${SLACK_ANALYST_APP_TOKEN}",
          "dmPolicy": "pairing"
        },
        "quant": {
          "name": "Quant - Technical & Quantitative",
          "botToken": "${SLACK_QUANT_BOT_TOKEN}",
          "appToken": "${SLACK_QUANT_APP_TOKEN}",
          "dmPolicy": "pairing"
        },
        "devils-advocate": {
          "name": "Devil's Advocate - Risk & Contrarian",
          "botToken": "${SLACK_DEVILS_ADVOCATE_BOT_TOKEN}",
          "appToken": "${SLACK_DEVILS_ADVOCATE_APP_TOKEN}",
          "dmPolicy": "pairing"
        }
      }
    }
  },
  "cron": {
    "enabled": true
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "controlUi": {
      "allowInsecureAuth": true
    },
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "contacts.add",
        "calendar.add",
        "reminders.add",
        "sms.send"
      ]
    }
  },
  "bindings": [
    {
      "agentId": "orchestrator",
      "match": { "channel": "slack", "accountId": "orchestrator" }
    },
    {
      "agentId": "scout",
      "match": { "channel": "slack", "accountId": "scout" }
    },
    {
      "agentId": "analyst",
      "match": { "channel": "slack", "accountId": "analyst" }
    },
    {
      "agentId": "quant",
      "match": { "channel": "slack", "accountId": "quant" }
    },
    {
      "agentId": "devils-advocate",
      "match": { "channel": "slack", "accountId": "devils-advocate" }
    }
  ]
}
