{
  "auth": {
    "profiles": {
      "openai-codex:rob.roskowski@gmail.com": {
        "provider": "openai-codex",
        "mode": "oauth",
        "email": "rob.roskowski@gmail.com"
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai-codex/gpt-5.4"
      },
      "models": {
        "openai-codex/gpt-5.4": {},
        "openai-codex/gpt-5.4-mini": {}
      },
      "workspace": "/home/clawadmin/.openclaw/workspace-orchestrator"
    },
    "list": [
      {
        "id": "orchestrator",
        "default": true,
        "name": "Orchestrator - Portfolio Manager",
        "workspace": "/home/clawadmin/.openclaw/workspace-orchestrator",
        "identity": {
          "name": "Orchestrator - Portfolio Manager",
          "emoji": "⚡"
        }
      },
      {
        "id": "scout",
        "name": "Scout - Market Intelligence",
        "workspace": "/home/clawadmin/.openclaw/workspace-scout",
        "identity": {
          "name": "Scout - Market Intelligence"
        }
      },
      {
        "id": "analyst",
        "name": "Analyst - Fundamental Research",
        "workspace": "/home/clawadmin/.openclaw/workspace-analyst",
        "identity": {
          "name": "Analyst - Fundamental Research"
        }
      },
      {
        "id": "quant",
        "name": "Quant - Technical & Quantitative",
        "workspace": "/home/clawadmin/.openclaw/workspace-quant",
        "identity": {
          "name": "Quant - Technical & Quantitative"
        }
      },
      {
        "id": "devils-advocate",
        "name": "Devil's Advocate - Risk & Contrarian",
        "workspace": "/home/clawadmin/.openclaw/workspace-devils-advocate",
        "identity": {
          "name": "Devil's Advocate - Risk & Contrarian"
        }
      }
    ]
  },
  "tools": {
    "profile": "full",
    "agentToAgent": {
      "enabled": true,
      "$comment": "A2A is enabled ONLY for pulling finished artifacts from another agent's files/ folder. Never use A2A for tasking, discussion, or coordination - those stay in Slack. See shared-skills/a2a-artifact-pull/SKILL.md."
    },
    "web": {
      "search": {
        "enabled": true,
        "provider": "duckduckgo"
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "command-logger": {
          "enabled": true
        },
        "session-memory": {
          "enabled": true
        }
      }
    }
  },
  "channels": {
    "slack": {
      "enabled": true,
      "mode": "socket",
      "defaultAccount": "orchestrator",
      "dmPolicy": "disabled",
      "groupPolicy": "allowlist",
      "dangerouslyAllowNameMatching": false,
      "webhookPath": "/slack/events",
      "capabilities": {
        "interactiveReplies": true
      },
      "actions": {
        "messages": true,
        "reactions": true,
        "pins": true,
        "memberInfo": true,
        "emojiList": true
      },
      "streaming": "partial",
      "nativeStreaming": true,
      "userTokenReadOnly": true,
      "channels": {
        "C0APJ5GE8Q2": {
          "allow": true,
          "requireMention": true,
          "allowBots": true
        },
        "C0APEJD4JSZ": {
          "allow": true,
          "requireMention": true,
          "allowBots": true
        },
        "C0APBNWUTGB": {
          "allow": true,
          "requireMention": true,
          "allowBots": true
        },
        "C0APX22FG9X": {
          "allow": true,
          "requireMention": true,
          "allowBots": true
        },
        "C0APBP8JJSX": {
          "allow": true,
          "requireMention": true,
          "allowBots": true
        },
        "C0APBP5MS4B": {
          "allow": true,
          "requireMention": true,
          "allowBots": false
        },
        "C0AQCD7Q1U0": {
          "allow": true,
          "requireMention": true,
          "allowBots": false
        },
        "C0AP4KWHXQF": {
          "allow": true,
          "requireMention": true,
          "allowBots": true
        },
        "C0APH5991U2": {
          "allow": true,
          "requireMention": true,
          "allowBots": true
        },
        "${SLACK_CHANNEL_WATCHLIST}": {
          "allow": true,
          "requireMention": true,
          "allowBots": true
        },
        "${SLACK_CHANNEL_WEEKLY_OUTLOOK}": {
          "allow": true,
          "requireMention": true,
          "allowBots": true
        }
      },
      "accounts": {
        "orchestrator": {
          "name": "Orchestrator - Portfolio Manager",
          "botToken": "${SLACK_ORCHESTRATOR_BOT_TOKEN}",
          "appToken": "${SLACK_ORCHESTRATOR_APP_TOKEN}",
          "dmPolicy": "pairing"
        },
        "scout": {
          "name": "Scout - Market Intelligence",
          "botToken": "${SLACK_SCOUT_BOT_TOKEN}",
          "appToken": "${SLACK_SCOUT_APP_TOKEN}",
          "dmPolicy": "disabled"
        },
        "analyst": {
          "name": "Analyst - Fundamental Research",
          "botToken": "${SLACK_ANALYST_BOT_TOKEN}",
          "appToken": "${SLACK_ANALYST_APP_TOKEN}",
          "dmPolicy": "disabled"
        },
        "quant": {
          "name": "Quant - Technical & Quantitative",
          "botToken": "${SLACK_QUANT_BOT_TOKEN}",
          "appToken": "${SLACK_QUANT_APP_TOKEN}",
          "dmPolicy": "disabled"
        },
        "devils-advocate": {
          "name": "Devil's Advocate - Risk & Contrarian",
          "botToken": "${SLACK_DEVILS_ADVOCATE_BOT_TOKEN}",
          "appToken": "${SLACK_DEVILS_ADVOCATE_APP_TOKEN}",
          "dmPolicy": "disabled"
        }
      }
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "controlUi": {
      "allowInsecureAuth": true
    },
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "contacts.add",
        "calendar.add",
        "reminders.add",
        "sms.send"
      ]
    }
  },
  "bindings": [
    {
      "agentId": "orchestrator",
      "match": { "channel": "slack", "accountId": "orchestrator" }
    },
    {
      "agentId": "scout",
      "match": { "channel": "slack", "accountId": "scout" }
    },
    {
      "agentId": "analyst",
      "match": { "channel": "slack", "accountId": "analyst" }
    },
    {
      "agentId": "quant",
      "match": { "channel": "slack", "accountId": "quant" }
    },
    {
      "agentId": "devils-advocate",
      "match": { "channel": "slack", "accountId": "devils-advocate" }
    }
  ],
  "plugins": {
    "entries": {
      "duckduckgo": {
        "enabled": true,
        "config": {}
      }
    }
  }
}
