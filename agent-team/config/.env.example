# Investment Agent Team - Environment Variables
#
# Copy this file to ~/.openclaw/.env on the VM and fill in real values.
# The openclaw.json config references these via ${VAR_NAME} interpolation.
#
# Env-source precedence (highest -> lowest):
# process env > ./.env > ~/.openclaw/.env > openclaw.json env block

# -----------------------------------------------------------------------------
# Gateway
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 24
OPENCLAW_GATEWAY_TOKEN=REPLACE_ME

# -----------------------------------------------------------------------------
# Slack - Orchestrator (Portfolio Manager)
# -----------------------------------------------------------------------------
SLACK_ORCHESTRATOR_BOT_TOKEN=xoxb-REPLACE_ME
SLACK_ORCHESTRATOR_APP_TOKEN=xapp-REPLACE_ME

# -----------------------------------------------------------------------------
# Slack - Scout (Market Intelligence)
# -----------------------------------------------------------------------------
SLACK_SCOUT_BOT_TOKEN=xoxb-REPLACE_ME
SLACK_SCOUT_APP_TOKEN=xapp-REPLACE_ME

# -----------------------------------------------------------------------------
# Slack - Analyst (Fundamental Research)
# -----------------------------------------------------------------------------
SLACK_ANALYST_BOT_TOKEN=xoxb-REPLACE_ME
SLACK_ANALYST_APP_TOKEN=xapp-REPLACE_ME

# -----------------------------------------------------------------------------
# Slack - Quant (Technical & Quantitative)
# -----------------------------------------------------------------------------
SLACK_QUANT_BOT_TOKEN=xoxb-REPLACE_ME
SLACK_QUANT_APP_TOKEN=xapp-REPLACE_ME

# -----------------------------------------------------------------------------
# Slack - Devil's Advocate (Risk & Contrarian)
# -----------------------------------------------------------------------------
SLACK_DEVILS_ADVOCATE_BOT_TOKEN=xoxb-REPLACE_ME
SLACK_DEVILS_ADVOCATE_APP_TOKEN=xapp-REPLACE_ME

# -----------------------------------------------------------------------------
# Slack Channel IDs
# Right-click channel in Slack -> View channel details -> ID at bottom
# -----------------------------------------------------------------------------
SLACK_CHANNEL_MARKET_SIGNALS=
SLACK_CHANNEL_RESEARCH=
SLACK_CHANNEL_QUANT_SIGNALS=
SLACK_CHANNEL_CONTRARIAN=
SLACK_CHANNEL_DISPATCH=
SLACK_CHANNEL_PORTFOLIO_DAILY=
SLACK_CHANNEL_PORTFOLIO_WEEKLY=
SLACK_CHANNEL_THEMES=
SLACK_CHANNEL_AGENTS=
SLACK_CHANNEL_WATCHLIST=
SLACK_CHANNEL_WEEKLY_OUTLOOK=
